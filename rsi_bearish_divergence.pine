//@version=6
indicator("Divergence RSI Bearish — Filtre Top de Marché",
          shorttitle    = "RSI BearDiv",
          overlay       = false,
          max_bars_back = 500)

// ══════════════════════════════════════════════════════════════════
// PARAMÈTRES
// ══════════════════════════════════════════════════════════════════
g1 = "Détection du signal"
rsi_len     = input.int(21,   "Période RSI",                          group=g1, minval=2)
piv_n       = input.int(3,    "Pivot N (bougies de chaque côté)",     group=g1, minval=1, maxval=10)
min_gap     = input.int(12,   "Écart mini entre A et C (sem.)",       group=g1, minval=2)
max_gap     = input.int(52,   "Écart maxi entre A et C (sem.)",       group=g1, maxval=200)
rsi_floor   = input.float(55, "RSI mini au sommet C",                 group=g1, minval=0, maxval=100)
min_ab_dist = input.float(5,  "Distance mini A→B sur RSI (points)",   group=g1, minval=0)

g2 = "Mesure de performance"
drop_pct = input.float(10, "Baisse minimale pour succès (%)", group=g2, minval=1)
fwd_bars = input.int(26,   "Fenêtre d'évaluation (semaines)", group=g2, minval=1)

// ══════════════════════════════════════════════════════════════════
// RSI
// ══════════════════════════════════════════════════════════════════
rsi = ta.rsi(close, rsi_len)

plot(rsi, "RSI", color=color.new(#e05252, 10), linewidth=2)
hline(70, "70", color=color.new(color.gray, 30), linestyle=hline.style_dashed)
hline(55, "55", color=color.new(color.purple, 20), linestyle=hline.style_dashed)
hline(30, "30", color=color.new(color.gray, 30), linestyle=hline.style_dashed)

// ══════════════════════════════════════════════════════════════════
// DÉTECTION DES PIVOTS HAUTS
// La confirmation arrive piv_n bougies après le pivot réel.
// Pivot réel = bar_index - piv_n au moment de la confirmation.
// ══════════════════════════════════════════════════════════════════
ph_price = ta.pivothigh(high, piv_n, piv_n)
ph_rsi   = ta.pivothigh(rsi,  piv_n, piv_n)

var float p1_price = na   // Prix au sommet A
var float p1_rsi   = na   // RSI au sommet A
var int   p1_bar   = na   // Barre du sommet A

// ══════════════════════════════════════════════════════════════════
// ÉTAT — divergence en attente de cassure de B
// ══════════════════════════════════════════════════════════════════
var float b_level = na    // Niveau RSI du creux B
var int   b_bar   = na    // Barre approximative de B (pour affichage)
var bool  pending = false // Divergence validée, en attente du signal

// ══════════════════════════════════════════════════════════════════
// ÉTAPE 1 — DÉTECTION DE LA DIVERGENCE (formation du sommet C)
//   ✔ Prix  : Higher High  (C.price > A.price)
//   ✔ RSI   : Lower High   (C.rsi   < A.rsi  )
//   ✔ Filtre: C.rsi > rsi_floor
//   ✔ Fenêtre: min_gap ≤ écart A–C ≤ max_gap
//   ✔ Distance A→B : A.rsi - B.rsi ≥ min_ab_dist
// ══════════════════════════════════════════════════════════════════
divergence = false

if not na(ph_price)
    p2_bar   = bar_index - piv_n
    p2_price = ph_price
    p2_rsi   = ph_rsi

    if p2_rsi > rsi_floor and not na(p1_bar)
        gap = p2_bar - p1_bar
        if gap >= min_gap and gap <= max_gap
            if p2_price > p1_price and p2_rsi < p1_rsi

                // Trouver B = minimum RSI entre A et C (exclu)
                float min_rsi_ab = 100.0
                int   min_rsi_i  = 1
                for i = 1 to gap - 1
                    val = rsi[piv_n + i]
                    if val < min_rsi_ab
                        min_rsi_ab := val
                        min_rsi_i  := i

                dist_ab = p1_rsi - min_rsi_ab

                if dist_ab >= min_ab_dist
                    divergence := true
                    b_level    := min_rsi_ab
                    b_bar      := p2_bar - min_rsi_i
                    pending    := true

                    // Ligne A→C sur le RSI (divergence)
                    line.new(p1_bar, p1_rsi, p2_bar, p2_rsi,
                             xloc  = xloc.bar_index,
                             color = color.fuchsia,
                             width = 2,
                             style = line.style_arrow_right)

                    // Niveau B — ligne horizontale pointillée jaune
                    // Étendu vers la droite pour visualiser la zone de cassure
                    line.new(b_bar, min_rsi_ab, p2_bar + 30, min_rsi_ab,
                             xloc  = xloc.bar_index,
                             color = color.new(color.yellow, 20),
                             width = 1,
                             style = line.style_dashed)

                    // Label B sur le RSI
                    label.new(b_bar, min_rsi_ab - 3,
                              text      = "B\n" + str.tostring(math.round(min_rsi_ab, 1)),
                              xloc      = xloc.bar_index,
                              yloc      = yloc.price,
                              color     = color.new(color.yellow, 20),
                              textcolor = color.black,
                              style     = label.style_label_up,
                              size      = size.tiny)

    p1_price := p2_price
    p1_rsi   := p2_rsi
    p1_bar   := p2_bar

// Losange jaune = divergence détectée au sommet C
plotshape(divergence, "Divergence (C)",
          style    = shape.diamond,
          location = location.abovebar,
          color    = color.yellow,
          size     = size.small)

// Fond jaune clair = divergence en attente de cassure
_bg_pending = pending and not divergence ? color.new(color.yellow, 92) : na
bgcolor(_bg_pending, title="En attente cassure B")

// ══════════════════════════════════════════════════════════════════
// ÉTAPE 2 — SIGNAL D'ENTRÉE : RSI passe sous le niveau B
// ══════════════════════════════════════════════════════════════════
signal = false

if pending and not na(b_level)
    if ta.crossunder(rsi, b_level)
        signal  := true
        pending := false

    // Invalidation : RSI repasse au-dessus du niveau A (divergence annulée)
    if rsi > p1_rsi
        pending := false
        b_level := na

// Triangle rouge = signal déclenché (cassure de B)
plotshape(signal, "Signal — Cassure B",
          style    = shape.triangledown,
          location = location.abovebar,
          color    = color.red,
          size     = size.normal)

bgcolor(signal ? color.new(color.red, 78) : na, title="Signal déclenché")

// ══════════════════════════════════════════════════════════════════
// SUCCÈS / ÉCHEC — évalué fwd_bars semaines après le signal
// ══════════════════════════════════════════════════════════════════
var int total_div      = 0   // Divergences détectées
var int total_signals  = 0   // Signaux déclenchés (cassure B)
var int total_evaluated= 0   // Signaux évalués
var int total_success  = 0   // Succès

if divergence and barstate.isconfirmed
    total_div += 1

if signal and barstate.isconfirmed
    total_signals += 1

was_signal = signal[fwd_bars]

if was_signal and barstate.isconfirmed
    total_evaluated += 1
    ref_price  = close[fwd_bars]
    min_low    = ta.lowest(low, fwd_bars)
    pct_drop   = (min_low - ref_price) / ref_price * 100
    is_success = pct_drop <= -drop_pct

    if is_success
        total_success += 1

    lbl_text  = (is_success ? "✓ " : "✗ ") + str.tostring(math.round(pct_drop, 1)) + "%"
    lbl_color = is_success ? color.new(color.teal, 10) : color.new(color.orange, 10)

    label.new(
      x         = bar_index - fwd_bars,
      y         = nz(rsi[fwd_bars], 60) + 8,
      text      = lbl_text,
      xloc      = xloc.bar_index,
      yloc      = yloc.price,
      color     = lbl_color,
      textcolor = color.white,
      style     = label.style_label_down,
      size      = size.small)

// ══════════════════════════════════════════════════════════════════
// TABLE DE STATISTIQUES
// ══════════════════════════════════════════════════════════════════
if barstate.islast
    win_rate   = total_evaluated > 0
                 ? math.round(total_success / total_evaluated * 100, 1)
                 : 0.0
    rate_color = win_rate >= 70 ? color.teal : win_rate >= 50 ? color.yellow : color.orange

    t = table.new(position.top_right, 2, 8,
                  bgcolor      = color.new(#0d0d1a, 5),
                  border_color = color.new(color.gray, 50),
                  border_width = 1,
                  frame_color  = color.new(color.gray, 30),
                  frame_width  = 1)

    table.cell(t, 0, 0, "RSI BEAR DIV — BACKTEST",
               text_color=color.white, bgcolor=color.new(color.purple, 20),
               text_halign=text.align_center, text_size=size.small)
    table.cell(t, 1, 0, "", bgcolor=color.new(color.purple, 20))

    table.cell(t, 0, 1, "RSI(" + str.tostring(rsi_len) + ")  N=" + str.tostring(piv_n)
               + "  A→B≥" + str.tostring(min_ab_dist) + "pts",
               text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 1, "Fenêtre " + str.tostring(min_gap) + "–" + str.tostring(max_gap) + " sem.",
               text_color=color.silver, text_halign=text.align_right, text_size=size.tiny)

    table.cell(t, 0, 2, "Divergences (A→B→C)",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(total_div),
               text_color=color.yellow, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 3, "Signaux (cassure B)",     text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(total_signals),
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 4, "Taux conversion div→sig", text_color=color.silver, text_size=size.tiny)
    conv = total_div > 0 ? math.round(total_signals / total_div * 100, 1) : 0.0
    table.cell(t, 1, 4, str.tostring(conv) + "%",
               text_color=color.silver, text_halign=text.align_right, text_size=size.tiny)

    table.cell(t, 0, 5, "Signaux évalués",         text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(total_evaluated),
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 6, "Succès (≥−" + str.tostring(drop_pct) + "%)",
               text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(total_success),
               text_color=color.teal, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 7, "Taux de réussite",        text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 7, str.tostring(win_rate) + "%",
               text_color=rate_color, text_halign=text.align_right, text_size=size.small)
