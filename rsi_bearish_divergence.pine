//@version=5
indicator("Divergence RSI Bearish — Filtre Top de Marché",
          shorttitle    = "RSI Bear Div",
          overlay       = false,
          max_bars_back = 500)

// ══════════════════════════════════════════════════════════════════
// PARAMÈTRES
// ══════════════════════════════════════════════════════════════════
g1 = "Détection du signal"
rsi_len   = input.int(21,   "Période RSI",                          group=g1, minval=2)
piv_n     = input.int(3,    "Pivot N (bougies de chaque côté)",     group=g1, minval=1, maxval=10)
min_gap   = input.int(12,   "Écart mini entre les 2 sommets (sem.)",group=g1, minval=2)
max_gap   = input.int(52,   "Écart maxi entre les 2 sommets (sem.)",group=g1, maxval=200)
rsi_floor = input.float(55, "RSI mini au 2ème sommet",              group=g1, minval=0, maxval=100)

g2 = "Mesure de performance"
drop_pct = input.float(10, "Baisse minimale pour succès (%)", group=g2, minval=1)
fwd_bars = input.int(26,   "Fenêtre d'évaluation (semaines)", group=g2, minval=1)

// ══════════════════════════════════════════════════════════════════
// RSI
// ══════════════════════════════════════════════════════════════════
rsi = ta.rsi(close, rsi_len)

plot(rsi, "RSI", color=color.new(#e05252, 10), linewidth=2)
hline(70, "70", color=color.new(color.gray, 30), linestyle=hline.style_dashed)
hline(55, "55", color=color.new(color.purple, 20), linestyle=hline.style_dashed)
hline(30, "30", color=color.new(color.gray, 30), linestyle=hline.style_dashed)

// ══════════════════════════════════════════════════════════════════
// DÉTECTION DES PIVOTS HAUTS
// Pivot confirmé N bougies après son occurrence réelle.
// bar_index - piv_n = barre réelle du pivot.
// ══════════════════════════════════════════════════════════════════
ph_price = ta.pivothigh(high, piv_n, piv_n)
ph_rsi   = ta.pivothigh(rsi,  piv_n, piv_n)

var float p1_price = na
var float p1_rsi   = na
var int   p1_bar   = na

// ══════════════════════════════════════════════════════════════════
// SIGNAL — DIVERGENCE BEARISH CLASSIQUE
//   ✔ Prix  : Higher High (P2.price > P1.price)
//   ✔ RSI   : Lower High  (P2.rsi   < P1.rsi  )
//   ✔ Filtre: RSI₂ > rsi_floor (default 55)
//   ✔ Fenêtre: min_gap ≤ écart barre ≤ max_gap
// ══════════════════════════════════════════════════════════════════
signal = false

if not na(ph_price)
    p2_bar   = bar_index - piv_n
    p2_price = ph_price
    p2_rsi   = ph_rsi

    if p2_rsi > rsi_floor and not na(p1_bar)
        gap = p2_bar - p1_bar
        if gap >= min_gap and gap <= max_gap
            if p2_price > p1_price and p2_rsi < p1_rsi
                signal := true
                // Ligne de divergence RSI entre les 2 sommets
                line.new(x1    = p1_bar,
                         y1    = p1_rsi,
                         x2    = p2_bar,
                         y2    = p2_rsi,
                         xloc  = xloc.bar_index,
                         color = color.fuchsia,
                         width = 2,
                         style = line.style_arrow_right)

    p1_price := p2_price
    p1_rsi   := p2_rsi
    p1_bar   := p2_bar

// ══════════════════════════════════════════════════════════════════
// AFFICHAGE DU SIGNAL
// ══════════════════════════════════════════════════════════════════
// Triangle rouge au moment de la confirmation
plotshape(signal, "Signal divergence",
          shape    = shape.triangledown,
          location = location.abovebar,
          color    = color.red,
          size     = size.normal)

// Fond rouge dans le panneau RSI
bgcolor(signal ? color.new(color.red, 78) : na, title="Zone alerte")

// ══════════════════════════════════════════════════════════════════
// SUCCÈS / ÉCHEC
// Évalué fwd_bars semaines après la confirmation du signal.
// Succès = baisse du close d'au moins drop_pct% sur la fenêtre.
// ══════════════════════════════════════════════════════════════════
var int total_detected = 0
var int total_evaluated = 0
var int total_success   = 0

// Comptage des signaux détectés (hors dernières fwd_bars bougies)
if signal and barstate.isconfirmed
    total_detected += 1

// Évaluation fwd_bars bougies après le signal
was_signal = signal[fwd_bars]

if was_signal and barstate.isconfirmed
    total_evaluated += 1

    ref_price  = close[fwd_bars]           // Close à la date du signal
    min_low    = ta.lowest(low, fwd_bars)  // Plus bas dans la fenêtre suivante
    pct_drop   = (min_low - ref_price) / ref_price * 100
    is_success = pct_drop <= -drop_pct

    if is_success
        total_success += 1

    lbl_text  = (is_success ? "✓ " : "✗ ") + str.tostring(math.round(pct_drop, 1)) + "%"
    lbl_color = is_success ? color.new(color.teal, 10) : color.new(color.orange, 10)

    label.new(
      x         = bar_index - fwd_bars,
      y         = nz(rsi[fwd_bars], 60) + 7,
      text      = lbl_text,
      xloc      = xloc.bar_index,
      yloc      = yloc.price,
      color     = lbl_color,
      textcolor = color.white,
      style     = label.style_label_down,
      size      = size.small)

// ══════════════════════════════════════════════════════════════════
// TABLE DE STATISTIQUES
// ══════════════════════════════════════════════════════════════════
if barstate.islast
    win_rate    = total_evaluated > 0
                  ? math.round(total_success / total_evaluated * 100, 1)
                  : 0.0
    rate_color  = win_rate >= 70 ? color.teal
                  : win_rate >= 50 ? color.yellow
                  : color.orange

    t = table.new(position.top_right, 2, 6,
                  bgcolor      = color.new(#0d0d1a, 5),
                  border_color = color.new(color.gray, 50),
                  border_width = 1,
                  frame_color  = color.new(color.gray, 30),
                  frame_width  = 1)

    // En-tête
    table.cell(t, 0, 0, "RSI BEAR DIV — BACKTEST",
               text_color  = color.white,
               bgcolor     = color.new(color.purple, 20),
               text_halign = text.align_center,
               text_size   = size.small)
    table.cell(t, 1, 0, "",
               bgcolor     = color.new(color.purple, 20))

    // Paramètres actifs
    table.cell(t, 0, 1, "RSI(" + str.tostring(rsi_len) + ")  Pivot N=" + str.tostring(piv_n),
               text_color  = color.silver,
               text_halign = text.align_left,
               text_size   = size.tiny)
    table.cell(t, 1, 1, "Fenêtre " + str.tostring(min_gap) + "–" + str.tostring(max_gap) + " sem.",
               text_color  = color.silver,
               text_halign = text.align_right,
               text_size   = size.tiny)

    // Stats
    table.cell(t, 0, 2, "Signaux détectés",  text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(total_detected),
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 3, "Signaux évalués",   text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(total_evaluated),
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 4, "Succès (≥−" + str.tostring(drop_pct) + "%)",
               text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(total_success),
               text_color=color.teal, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 5, "Taux de réussite",  text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(win_rate) + "%",
               text_color=rate_color, text_halign=text.align_right, text_size=size.small)
