//@version=6
indicator("Divergence RSI Bearish — Filtre Top de Marché",
          shorttitle    = "RSI BearDiv",
          overlay       = false,
          max_bars_back = 500)

// ══════════════════════════════════════════════════════════════════
// PARAMÈTRES
// ══════════════════════════════════════════════════════════════════
g1 = "Détection"
rsi_len     = input.int(21,   "Période RSI",                  group=g1, minval=2)
piv_n       = input.int(3,    "Pivot N — confirmation de C",  group=g1, minval=1, maxval=10)
max_gap     = input.int(52,   "Lookback max A→C (semaines)",  group=g1, minval=4, maxval=200)
rsi_floor   = input.float(55, "RSI mini au sommet C",         group=g1, minval=0, maxval=100)
min_ab_dist = input.float(5,  "Distance mini A→B (pts RSI)", group=g1, minval=0)

g2 = "Performance"
drop_pct = input.float(10, "Baisse min pour succès (%)", group=g2, minval=1)
fwd_bars = input.int(26,   "Fenêtre évaluation (sem.)",  group=g2, minval=1)

// ══════════════════════════════════════════════════════════════════
// RSI
// ══════════════════════════════════════════════════════════════════
rsi = ta.rsi(close, rsi_len)

plot(rsi, "RSI", color=color.new(#e05252, 10), linewidth=2)
hline(70, "70", color=color.new(color.gray,   30), linestyle=hline.style_dashed)
hline(55, "55", color=color.new(color.purple, 20), linestyle=hline.style_dashed)
hline(50, "50", color=color.new(color.gray,   50), linestyle=hline.style_dotted)
hline(30, "30", color=color.new(color.gray,   30), linestyle=hline.style_dashed)

// ══════════════════════════════════════════════════════════════════
// PIVOT C — sommet local confirmé (N bougies de chaque côté)
// C est le 2ème sommet de la divergence, confirmé N barres après
// son occurrence réelle (bar réelle = bar_index - piv_n).
// ══════════════════════════════════════════════════════════════════
ph_price = ta.pivothigh(high, piv_n, piv_n)
ph_rsi   = ta.pivothigh(rsi,  piv_n, piv_n)

// ══════════════════════════════════════════════════════════════════
// ÉTAT — divergence validée, en attente de cassure de B
// ══════════════════════════════════════════════════════════════════
var float b_level   = na   // Niveau RSI du creux B (seuil d'entrée)
var float div_a_rsi = na   // RSI de A (pour invalidation)
var bool  pending   = false

// ══════════════════════════════════════════════════════════════════
// DÉTECTION DE LA DIVERGENCE
//
// Règles (définies à partir des exemples historiques) :
//   A = maximum RSI ABSOLU dans la fenêtre lookback avant C
//       → c'est le plus haut RSI de la phase haussière en cours
//
//   C = sommet local du RSI (pivot N) tel que :
//       ✔ C.rsi  < A.rsi     (Lower High RSI  → divergence)
//       ✔ C.high > A.high    (Higher High prix → divergence)
//       ✔ C.rsi  > rsi_floor (encore en territoire haussier)
//
//   B = minimum RSI strictement entre A et C tel que :
//       ✔ A.rsi - B.rsi ≥ min_ab_dist  (pullback suffisant)
//       ✔ B.rsi ≥ 50                   (pas encore en correction)
//
//   Signal = RSI croise sous le niveau B après C confirmé
// ══════════════════════════════════════════════════════════════════
divergence = false

if not na(ph_price)
    p2_bar   = bar_index - piv_n   // barre réelle du sommet C
    p2_rsi   = ph_rsi              // RSI au sommet C
    p2_price = ph_price            // High au sommet C

    if p2_rsi > rsi_floor

        // ── Étape 1 : Trouver A = max RSI absolu avant C ──────────
        float a_rsi    = na
        float a_price  = na
        int   a_offset = na        // offset depuis bar_index

        for i = piv_n + 1 to piv_n + max_gap
            if bar_index - i >= 0
                r = rsi[i]
                if na(a_rsi) or r > a_rsi
                    a_rsi    := r
                    a_price  := high[i]
                    a_offset := i

        if not na(a_rsi)
            a_bar = bar_index - a_offset
            gap   = p2_bar - a_bar   // écart en barres entre A et C

            // ── Étape 2 : Vérifier la divergence A→C ──────────────
            if gap >= 2 and p2_rsi < a_rsi and p2_price > a_price

                // ── Étape 3 : Trouver B = min RSI entre A et C ────
                float b_rsi    = 100.0
                int   b_offset = piv_n + 1

                for j = 1 to gap - 1
                    val = rsi[piv_n + j]
                    if val < b_rsi
                        b_rsi    := val
                        b_offset := piv_n + j

                dist_ab = a_rsi - b_rsi

                // ── Étape 4 : Valider les conditions sur B ─────────
                if dist_ab >= min_ab_dist and b_rsi >= 50

                    divergence  := true
                    b_level     := b_rsi
                    div_a_rsi   := a_rsi
                    pending     := true

                    b_bar = bar_index - b_offset

                    // Ligne A→C (divergence RSI)
                    line.new(a_bar, a_rsi, p2_bar, p2_rsi,
                             xloc  = xloc.bar_index,
                             color = color.fuchsia,
                             width = 2,
                             style = line.style_arrow_right)

                    // Niveau B — pointillé jaune étendu vers la droite
                    line.new(a_bar, b_rsi, p2_bar + 40, b_rsi,
                             xloc  = xloc.bar_index,
                             color = color.new(color.yellow, 20),
                             width = 1,
                             style = line.style_dashed)

                    // Label B
                    label.new(b_bar, b_rsi - 3,
                              text      = "B " + str.tostring(math.round(b_rsi, 1)),
                              xloc      = xloc.bar_index,
                              yloc      = yloc.price,
                              color     = color.new(color.yellow, 20),
                              textcolor = color.black,
                              style     = label.style_label_up,
                              size      = size.tiny)

// Losange jaune au sommet C
plotshape(divergence, "Divergence (C)",
          style    = shape.diamond,
          location = location.abovebar,
          color    = color.yellow,
          size     = size.small)

// Fond jaune = divergence en attente de cassure B
_bg_wait = pending and not divergence ? color.new(color.yellow, 92) : na
bgcolor(_bg_wait, title="En attente cassure B")

// ══════════════════════════════════════════════════════════════════
// SIGNAL D'ENTRÉE : RSI croise sous le niveau B
// ══════════════════════════════════════════════════════════════════
signal = false

if pending and not na(b_level)
    if ta.crossunder(rsi, b_level)
        signal  := true
        pending := false
    // Invalidation : RSI repasse au-dessus de A → divergence annulée
    if not na(div_a_rsi) and rsi > div_a_rsi
        pending   := false
        b_level   := na
        div_a_rsi := na

plotshape(signal, "Signal — Cassure B",
          style    = shape.triangledown,
          location = location.abovebar,
          color    = color.red,
          size     = size.normal)

bgcolor(signal ? color.new(color.red, 78) : na, title="Signal déclenché")

// ══════════════════════════════════════════════════════════════════
// SUCCÈS / ÉCHEC — évalué fwd_bars semaines après le signal
// ref_price = close à la date du signal
// succès    = min(low) dans la fenêtre ≤ ref_price × (1 - drop_pct%)
// ══════════════════════════════════════════════════════════════════
var int total_div       = 0
var int total_signals   = 0
var int total_evaluated = 0
var int total_success   = 0

if divergence and barstate.isconfirmed
    total_div += 1
if signal and barstate.isconfirmed
    total_signals += 1

was_signal = signal[fwd_bars]

if was_signal and barstate.isconfirmed
    total_evaluated += 1
    ref_price  = close[fwd_bars]
    min_low    = ta.lowest(low, fwd_bars)
    pct_drop   = (min_low - ref_price) / ref_price * 100
    is_success = pct_drop <= -drop_pct

    if is_success
        total_success += 1

    label.new(
      x         = bar_index - fwd_bars,
      y         = nz(rsi[fwd_bars], 60) + 8,
      text      = (is_success ? "✓ " : "✗ ") + str.tostring(math.round(pct_drop, 1)) + "%",
      xloc      = xloc.bar_index,
      yloc      = yloc.price,
      color     = is_success ? color.new(color.teal, 10) : color.new(color.orange, 10),
      textcolor = color.white,
      style     = label.style_label_down,
      size      = size.small)

// ══════════════════════════════════════════════════════════════════
// TABLE DE STATISTIQUES
// ══════════════════════════════════════════════════════════════════
if barstate.islast
    win_rate   = total_evaluated > 0
                 ? math.round(total_success / total_evaluated * 100, 1) : 0.0
    rate_color = win_rate >= 70 ? color.teal : win_rate >= 50 ? color.yellow : color.orange
    conv_rate  = total_div > 0
                 ? math.round(total_signals / total_div * 100, 1) : 0.0

    t = table.new(position.top_right, 2, 8,
                  bgcolor      = color.new(#0d0d1a, 5),
                  border_color = color.new(color.gray, 50),
                  border_width = 1,
                  frame_color  = color.new(color.gray, 30),
                  frame_width  = 1)

    table.cell(t, 0, 0, "RSI BEAR DIV — BACKTEST",
               text_color=color.white, bgcolor=color.new(color.purple, 20),
               text_halign=text.align_center, text_size=size.small)
    table.cell(t, 1, 0, "", bgcolor=color.new(color.purple, 20))

    table.cell(t, 0, 1,
               "RSI(" + str.tostring(rsi_len) + ")  N=" + str.tostring(piv_n)
               + "  A→B≥" + str.tostring(min_ab_dist) + "pts",
               text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 1, "Lookback " + str.tostring(max_gap) + " sem.",
               text_color=color.silver, text_halign=text.align_right, text_size=size.tiny)

    table.cell(t, 0, 2, "Divergences (A→B→C)",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(total_div),
               text_color=color.yellow, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 3, "Signaux (cassure B)",     text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(total_signals),
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 4, "Taux conversion div→sig", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(conv_rate) + "%",
               text_color=color.silver, text_halign=text.align_right, text_size=size.tiny)

    table.cell(t, 0, 5, "Signaux évalués",         text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(total_evaluated),
               text_color=color.white, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 6, "Succès (≥−" + str.tostring(drop_pct) + "%)",
               text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(total_success),
               text_color=color.teal, text_halign=text.align_right, text_size=size.small)

    table.cell(t, 0, 7, "Taux de réussite",        text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 7, str.tostring(win_rate) + "%",
               text_color=rate_color, text_halign=text.align_right, text_size=size.small)
